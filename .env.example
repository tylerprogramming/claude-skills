# Gmail address for journal email summaries
GMAIL_ADDRESS=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-app-password

# OpenAI API key (for transcribe skill)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Kie.ai API key (for thumbnail skill)
# Get one at: https://kie.ai/api-key
KIE_API_KEY=your-kie-api-key

# Apify API token (for tiktok skill)
# Get one at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your-apify-api-token
